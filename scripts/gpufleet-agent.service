[Unit]
Description=GPUFleet Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/gpufleet/agent.env
ExecStart=/usr/local/bin/gpufleet-agent \
  -queue-path /var/lib/gpufleet-agent/queue
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/gpufleet-agent

[Install]
WantedBy=multi-user.target
